# 哨响AI v6.0 环境变量模板
# ==============================
# 复制此文件为 .env 并填入真实值
# .env 已在 .gitignore 中，不会被提交到版本控制

# ── 运行模式 ──────────────────────────────
DEBUG=false
LOG_LEVEL=INFO

# ── 服务器配置 ───────────────────────────
API_HOST=0.0.0.0
API_PORT=9000

# ── 安全 ─────────────────────────────────
SECRET_KEY=在此填入至少32字符的随机密钥
ADMIN_USERNAME=admin
ADMIN_PASSWORD=在此填入管理员密码
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── CORS ─────────────────────────────────
CORS_ORIGINS=["http://localhost:9000","http://localhost:5173"]

# ── 数据库 ───────────────────────────────
DATABASE_URL="sqlite:///./data/football_data.db"

# ── API 密钥 ─────────────────────────────
# Football-Data.org (免费注册: https://www.football-data.org/)
FOOTBALL_DATA_API_KEY=在此填入API密钥

# The Odds API (https://the-odds-api.com/)
THE_ODDS_API_KEY=在此填入API密钥

# The Odds API 赔率 Widget 专用 access key (wk_ 前缀, 可选)
# 用于 /api/widget-url 端点拼接官方赔率 widget URL (iframe 嵌入)
# 留空则自动回退使用 THE_ODDS_API_KEY (已验证可用于 widget 端点)
# 获取/重置: the-odds-api.com 控制台 → 账户 → Widget 订阅 → 管理 access key → Regenerate
WIDGET_ACCESS_KEY=在此填入Widget专用accessKey_可选_留空则回退THE_ODDS_API_KEY

# ── OCR 服务 ────────────────────────────
OCR_AK=在此填入OCR Access Key
OCR_SK=在此填入OCR Secret Key

# ── GPU ─────────────────────────────────
# RTX 5070 Ti sm_120不兼容，留空强制CPU
CUDA_VISIBLE_DEVICES=

# ── 告警通知 (可选) ──────────────────────
# SLACK_WEBHOOK_URL=
# WECOM_WEBHOOK_URL=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
