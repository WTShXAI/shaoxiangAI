# 哨响AI 本地部署环境变量模板
# 复制此文件为 .env 并填入实际值

DEBUG=true
API_HOST=0.0.0.0
API_PORT=9000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# 安全密钥（生产环境务必修改）
# 生成随机密钥: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars

# SQLite 数据库路径
DATABASE_URL=sqlite:///./data/football_data.db

# 数据采集 API Key
FOOTBALL_DATA_API_KEY=your_api_key_here

# GPU 设置（设为空字符串表示仅使用 CPU）
CUDA_VISIBLE_DEVICES=

# OCR 服务密钥（可选）
OCR_AK=your_ak_here
OCR_SK=your_sk_here
