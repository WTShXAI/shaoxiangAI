# 哨响AI v4.1 本地部署环境变量 (模板)
# 复制此文件为 .env 并填入实际值

DEBUG=true
API_HOST=0.0.0.0
API_PORT=9000
# 本地开发用随机值: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-random-secret
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# 火山引擎 OCR（豆包视觉）- 如需使用OCR功能请填入
OCR_AK=your_ak_here
OCR_SK=your_sk_here

CUDA_VISIBLE_DEVICES=

# SQLite 数据库路径
DATABASE_URL="sqlite:///D:/Architecture v4.0/data/football_data.db"

# 数据采集 API Key (football-data.org)
FOOTBALL_DATA_API_KEY=your_api_key_here
